{
  "name": "sugya",
  "version": "1.0.0",
  "description": "Talmud learning desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.sugya.app",
    "productName": "Sugya",
    "icon": "src/icon.png",
    "win": {
      "target": "nsis",
      "icon": "src/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "shortcutName": "Sugya"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../talmud/pdfs",
        "to": "pdfs"
      },
      {
        "from": "src/ocr-data",
        "to": "ocr-data"
      }
    ]
  },
  "dependencies": {
    "pdfjs-dist": "^4.4.168"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1"
  }
}
