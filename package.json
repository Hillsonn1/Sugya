{
  "name": "sugya",
  "version": "1.0.0",
  "description": "Talmud learning desktop app",
  "author": "Sugya",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win && \"%LOCALAPPDATA%\\Programs\\Inno Setup 6\\ISCC.exe\" sugya.iss"
  },
  "build": {
    "appId": "com.sugya.app",
    "productName": "Sugya",
    "icon": "src/icon.png",
    "win": {
      "target": [
        { "target": "dir", "arch": ["x64"] }
      ],
      "icon": "src/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../talmud/pdfs",
        "to": "pdfs"
      },
      {
        "from": "src/ocr-data",
        "to": "ocr-data"
      },
      {
        "from": "src/commentary-data",
        "to": "commentary-data"
      }
    ]
  },
  "dependencies": {
    "pdfjs-dist": "^4.4.168"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1"
  }
}
